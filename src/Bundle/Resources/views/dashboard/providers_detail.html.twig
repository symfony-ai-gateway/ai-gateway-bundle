{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Provider {{ provider.name }}{% endblock %}

{% block content %}
<div class="toolbar">
    <div>
        <h1 class="page-title">Provider: {{ provider.name }}</h1>
        <div class="subtitle">Provider-level traffic, downstream model usage, cost, and error analysis.</div>
    </div>
    <div style="display:flex;gap:8px">
        <span class="pill">{{ provider.format }}</span>
        <a href="{{ dash.turl('/dashboard/providers/' ~ provider.name ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary">Edit</a>
    </div>
</div>

<div class="metric-grid">
    <div class="card"><h3>Requests</h3><div class="value blue">{{ provider_stats.requests|number_format }}</div></div>
    <div class="card"><h3>Tokens</h3><div class="value green">{{ provider_stats.tokens|number_format }}</div></div>
    <div class="card"><h3>Cost</h3><div class="value yellow">${{ provider_stats.cost|number_format(4) }}</div></div>
    <div class="card"><h3>Errors</h3><div class="value {% if provider_stats.errors > 0 %}red{% else %}green{% endif %}">{{ provider_stats.errors|number_format }}</div></div>
    <div class="card"><h3>Avg Duration</h3><div class="value" style="color:var(--accent2)">{{ provider_stats.avg_duration_ms|number_format(1) }}ms</div></div>
    <div class="card"><h3>Base URL</h3><div class="value" style="font-size:16px;color:var(--text)">{{ provider.base_url ?: 'default' }}</div></div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Daily activity</h3>
        {% set provider_daily_max = daily_usage|length ? max(daily_usage|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in daily_usage %}
                <div class="chart-row">
                    <div class="chart-label mono">{{ row.date }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ provider_daily_max > 0 ? (row.requests / provider_daily_max * 100) : 0 }}%;"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }} req · ${{ row.cost|number_format(2) }}</div>
                </div>
            {% else %}
                <div class="muted">No activity yet.</div>
            {% endfor %}
        </div>
    </div>
    <div class="card">
        <h3>Status distribution</h3>
        {% set provider_status_max = status_breakdown|length ? max(status_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in status_breakdown %}
                {% set status_color = row.family starts with '2' ? 'var(--success)' : (row.family starts with '4' ? 'var(--warning)' : (row.family starts with '5' ? 'var(--danger)' : 'var(--primary)')) %}
                <div class="chart-row">
                    <div class="chart-label"><span class="badge badge-blue">{{ row.family }}</span></div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ provider_status_max > 0 ? (row.requests / provider_status_max * 100) : 0 }}%; --bar-color: {{ status_color }};"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No status data yet.</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Requested aliases on this provider</h3>
        {% set provider_alias_max = model_breakdown|length ? max(model_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in model_breakdown %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.label }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ provider_alias_max > 0 ? (row.requests / provider_alias_max * 100) : 0 }}%; --bar-color: var(--info);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No alias data yet.</div>
            {% endfor %}
        </div>
    </div>
    <div class="card">
        <h3>Resolved models on this provider</h3>
        {% set provider_resolved_max = resolved_model_breakdown|length ? max(resolved_model_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in resolved_model_breakdown %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.label }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ provider_resolved_max > 0 ? (row.requests / provider_resolved_max * 100) : 0 }}%; --bar-color: var(--success);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No resolved model data yet.</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Top API keys</h3>
        {% set provider_keys_max = top_keys|length ? max(top_keys|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in top_keys %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.key_name ?: 'anonymous' }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ provider_keys_max > 0 ? (row.requests / provider_keys_max * 100) : 0 }}%; --bar-color: var(--warning);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No key data yet.</div>
            {% endfor %}
        </div>
    </div>
    <div class="card">
        <h3>Top teams</h3>
        {% set provider_teams_max = top_teams|length ? max(top_teams|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in top_teams %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.team_name ?: 'No team' }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ provider_teams_max > 0 ? (row.requests / provider_teams_max * 100) : 0 }}%; --bar-color: var(--primary);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No team data yet.</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="section">
    <h2>Recent requests</h2>
    <div class="card table-card">
        <div class="table-scroll">
        <table class="wide-table">
            <thead><tr><th>Time</th><th>Alias</th><th>Resolved Model</th><th>Provider</th><th>API Key</th><th>Team</th><th>Prompt</th><th>Comp.</th><th>Total</th><th>Cost</th><th>Duration</th><th>Status</th><th>Error</th></tr></thead>
            <tbody>
            {% for log in recent_logs %}
                <tr>
                    <td class="mono">{{ log.created_at|date('Y-m-d H:i:s') }}</td>
                    <td>{{ log.model_alias }}</td>
                    <td class="mono">{{ log.resolved_model ?: '—' }}</td>
                    <td>{{ log.provider_name }}</td>
                    <td>{% if log.key_id %}<a href="{{ dash.turl('/dashboard/keys/' ~ log.key_id, dashboard_token|default('')) }}">{{ log.key_name ?: 'anonymous' }}</a>{% else %}<span class="muted">anonymous</span>{% endif %}</td>
                    <td>{% if log.team_id %}<a href="{{ dash.turl('/dashboard/teams/' ~ log.team_id, dashboard_token|default('')) }}">{{ log.team_name ?: 'team #' ~ log.team_id }}</a>{% else %}<span class="muted">—</span>{% endif %}</td>
                    <td>{{ log.prompt_tokens|number_format }}</td>
                    <td>{{ log.completion_tokens|number_format }}</td>
                    <td>{{ log.total_tokens|number_format }}</td>
                    <td style="color:var(--yellow)">${{ log.cost_usd|number_format(6) }}</td>
                    <td>{{ log.duration_ms ?: 0 }}ms</td>
                    <td>{% if log.status_code >= 500 %}<span class="badge badge-red">{{ log.status_code }}</span>{% elseif log.status_code >= 400 %}<span class="badge badge-yellow">{{ log.status_code }}</span>{% else %}<span class="badge badge-green">{{ log.status_code }}</span>{% endif %}</td>
                    <td class="mono" style="max-width:200px;white-space:normal;color:var(--text2)">{{ log.error ?: '—' }}</td>
                </tr>
            {% else %}
                <tr><td colspan="13" style="padding:16px" class="muted">No provider traffic yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}

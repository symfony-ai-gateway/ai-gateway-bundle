{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Teams{% endblock %}

{% block content %}
<div class="toolbar">
    <h1 class="page-title">Teams</h1>
    <a href="{{ dash.turl('/dashboard/teams/new', dashboard_token|default('')) }}" class="btn btn-primary">+ New Team</a>
</div>

<div class="card table-card">
    <div class="table-scroll">
    <table>
        <thead><tr><th>Name</th><th>Keys</th><th>Requests</th><th>Cost</th><th>Budget/Day</th><th>Budget/Month</th><th></th></tr></thead>
        <tbody>
        {% for team in teams %}
            <tr>
                <td><a href="{{ dash.turl('/dashboard/teams/' ~ team.id, dashboard_token|default('')) }}">{{ team.name }}</a></td>
                <td>{{ team_key_counts[team.id] ?? 0 }}</td>
                <td>{{ team_stats_map[team.id].requests|default(0)|number_format }}</td>
                <td style="color:var(--yellow)">${{ team_stats_map[team.id].cost|default(0)|number_format(4) }}</td>
                <td>{{ team.budgetPerDay ? '$' ~ team.budgetPerDay|number_format(2) : 'none' }}</td>
                <td>{{ team.budgetPerMonth ? '$' ~ team.budgetPerMonth|number_format(2) : 'none' }}</td>
                <td><a href="{{ dash.turl('/dashboard/teams/' ~ team.id, dashboard_token|default('')) }}">view →</a></td>
            </tr>
        {% else %}
            <tr><td colspan="7" style="padding:16px;color:var(--text2)">No teams yet.</td></tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
</div>
{% endblock %}

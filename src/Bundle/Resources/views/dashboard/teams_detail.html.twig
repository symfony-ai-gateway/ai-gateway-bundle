{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Team {{ team.name }}{% endblock %}

{% block content %}
<div class="toolbar">
    <div>
        <h1 class="page-title">Team: {{ team.name }}</h1>
        <div class="subtitle">Governance-level analytics for all keys and requests belonging to this team.</div>
    </div>
    <a href="{{ dash.turl('/dashboard/teams/' ~ team.id ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary">Edit</a>
</div>

<div class="metric-grid">
    <div class="card"><h3>Requests</h3><div class="value blue">{{ team_stats.requests|number_format }}</div></div>
    <div class="card"><h3>Tokens</h3><div class="value green">{{ team_stats.tokens|number_format }}</div></div>
    <div class="card"><h3>Cost</h3><div class="value yellow">${{ team_stats.cost|number_format(4) }}</div></div>
    <div class="card"><h3>Errors</h3><div class="value {% if team_stats.errors > 0 %}red{% else %}green{% endif %}">{{ team_stats.errors|number_format }}</div></div>
    <div class="card"><h3>Avg Duration</h3><div class="value" style="color:var(--accent2)">{{ team_stats.avg_duration_ms|number_format(1) }}ms</div></div>
    <div class="card"><h3>Keys</h3><div class="value" style="color:var(--accent2)">{{ keys|length }}</div></div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Rules</h3>
        <dl class="def-list">
            <dt>Budget / Day</dt><dd>{{ team.budgetPerDay ? '$' ~ team.budgetPerDay|number_format(2) : 'none' }}</dd>
            <dt>Budget / Month</dt><dd>{{ team.budgetPerMonth ? '$' ~ team.budgetPerMonth|number_format(2) : 'none' }}</dd>
            <dt>Rate Limit</dt><dd>{{ team.rateLimitPerMinute ? team.rateLimitPerMinute ~ ' req/min' : 'none' }}</dd>
        </dl>
    </div>
    <div class="card">
        <h3>API Keys</h3>
        <ul class="stack-list">
        {% for key in keys %}
            <li><a href="{{ dash.turl('/dashboard/keys/' ~ key.id, dashboard_token|default('')) }}">{{ key.name }}</a></li>
        {% else %}
            <li class="muted">No keys yet.</li>
        {% endfor %}
        </ul>
    </div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Daily activity</h3>
        {% set team_daily_max = daily_usage|length ? max(daily_usage|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in daily_usage %}
                <div class="chart-row">
                    <div class="chart-label mono">{{ row.date }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ team_daily_max > 0 ? (row.requests / team_daily_max * 100) : 0 }}%;"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }} req · ${{ row.cost|number_format(2) }}</div>
                </div>
            {% else %}
                <div class="muted">No activity yet.</div>
            {% endfor %}
        </div>
    </div>
    <div class="card">
        <h3>Status distribution</h3>
        {% set team_status_max = status_breakdown|length ? max(status_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in status_breakdown %}
                {% set status_color = row.family starts with '2' ? 'var(--success)' : (row.family starts with '4' ? 'var(--warning)' : (row.family starts with '5' ? 'var(--danger)' : 'var(--primary)')) %}
                <div class="chart-row">
                    <div class="chart-label"><span class="badge badge-blue">{{ row.family }}</span></div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ team_status_max > 0 ? (row.requests / team_status_max * 100) : 0 }}%; --bar-color: {{ status_color }};"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No status data yet.</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Providers used</h3>
        {% set team_provider_max = provider_breakdown|length ? max(provider_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in provider_breakdown %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.label }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ team_provider_max > 0 ? (row.requests / team_provider_max * 100) : 0 }}%; --bar-color: var(--info);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No provider data yet.</div>
            {% endfor %}
        </div>
    </div>
    <div class="card">
        <h3>Models used</h3>
        {% set team_model_max = model_breakdown|length ? max(model_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in model_breakdown %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.label }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ team_model_max > 0 ? (row.requests / team_model_max * 100) : 0 }}%; --bar-color: var(--primary);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No model data yet.</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="grid grid-2 section">
    <div class="card">
        <h3>Top API keys inside this team</h3>
        {% set team_key_max = key_breakdown|length ? max(key_breakdown|map(v => v.requests)) : 1 %}
        <div class="chart-list">
            {% for row in key_breakdown %}
                <div class="chart-row">
                    <div class="chart-label">{{ row.key_name ?: 'anonymous' }}</div>
                    <div class="chart-track"><div class="chart-fill" style="width: {{ team_key_max > 0 ? (row.requests / team_key_max * 100) : 0 }}%; --bar-color: var(--warning);"></div></div>
                    <div class="chart-meta">{{ row.requests|number_format }}</div>
                </div>
            {% else %}
                <div class="muted">No key data yet.</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="section">
    <h2>Recent requests</h2>
    <div class="card table-card">
        <div class="table-scroll">
        <table class="wide-table">
            <thead><tr><th>Time</th><th>Alias</th><th>Resolved Model</th><th>Provider</th><th>API Key</th><th>Prompt</th><th>Comp.</th><th>Total</th><th>Cost</th><th>Duration</th><th>Status</th><th>Error</th></tr></thead>
            <tbody>
            {% for log in recent_logs %}
                <tr>
                    <td class="mono">{{ log.created_at|date('Y-m-d H:i:s') }}</td>
                    <td>{{ log.model_alias }}</td>
                    <td class="mono">{{ log.resolved_model ?: '—' }}</td>
                    <td>{{ log.provider_name }}</td>
                    <td>{% if log.key_id %}<a href="{{ dash.turl('/dashboard/keys/' ~ log.key_id, dashboard_token|default('')) }}">{{ log.key_name ?: 'anonymous' }}</a>{% else %}<span class="muted">anonymous</span>{% endif %}</td>
                    <td>{{ log.prompt_tokens|number_format }}</td>
                    <td>{{ log.completion_tokens|number_format }}</td>
                    <td>{{ log.total_tokens|number_format }}</td>
                    <td style="color:var(--yellow)">${{ log.cost_usd|number_format(6) }}</td>
                    <td>{{ log.duration_ms ?: 0 }}ms</td>
                    <td>{% if log.status_code >= 500 %}<span class="badge badge-red">{{ log.status_code }}</span>{% elseif log.status_code >= 400 %}<span class="badge badge-yellow">{{ log.status_code }}</span>{% else %}<span class="badge badge-green">{{ log.status_code }}</span>{% endif %}</td>
                    <td class="mono" style="max-width:200px;white-space:normal;color:var(--text2)">{{ log.error ?: '—' }}</td>
                </tr>
            {% else %}
                <tr><td colspan="12" style="padding:16px" class="muted">No requests yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}

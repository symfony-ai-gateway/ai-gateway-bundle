{% macro turl(path, dashboard_token) %}{{ path }}{% if dashboard_token %}?token={{ dashboard_token }}{% endif %}{% endmacro %}
{% import _self as dash %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AIGateway Dashboard{% endblock %}</title>
    <style>
        :root {
            color-scheme: dark;
            --bg: #0a1020;
            --bg-elev: rgba(15, 23, 42, .72);
            --surface: rgba(17, 24, 39, .92);
            --surface-2: rgba(30, 41, 59, .96);
            --surface2: rgba(30, 41, 59, .96);
            --surface-3: rgba(51, 65, 85, .72);
            --border: rgba(148, 163, 184, .16);
            --text: #e5eefb;
            --muted: #94a3b8;
            --text2: #94a3b8;
            --primary: #6366f1;
            --primary-strong: #4f46e5;
            --accent2: #8b5cf6;
            --info: #38bdf8;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --radius: 18px;
            --radius-sm: 12px;
            --shadow: 0 18px 48px rgba(2, 6, 23, .32);
            --mono: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            --sans: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        * { box-sizing: border-box; }
        html, body { min-height: 100%; }
        body {
            margin: 0;
            font-family: var(--sans);
            background:
                radial-gradient(circle at top left, rgba(99, 102, 241, .18), transparent 30%),
                radial-gradient(circle at 80% 0%, rgba(56, 189, 248, .13), transparent 25%),
                linear-gradient(180deg, #0a1020 0%, #0b1224 100%);
            color: var(--text);
        }

        body.sidebar-open { overflow: hidden; }

        a { color: inherit; text-decoration: none; }
        a:hover { color: inherit; }

        .dashboard-shell {
            display: grid;
            grid-template-columns: 280px minmax(0, 1fr);
            min-height: 100vh;
        }

        .sidebar {
            position: sticky;
            top: 0;
            height: 100vh;
            overflow: auto;
            padding: 20px;
            background: linear-gradient(180deg, rgba(15, 23, 42, .96), rgba(15, 23, 42, .78));
            border-right: 1px solid var(--border);
            backdrop-filter: blur(18px);
            z-index: 50;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 4px 4px 18px;
            margin-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }

        .brand-mark {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary), #8b5cf6 50%, var(--info));
            box-shadow: 0 14px 30px rgba(99, 102, 241, .35);
        }

        .brand h1 {
            margin: 0;
            font-size: 18px;
            letter-spacing: -.03em;
        }

        .brand p {
            margin: 3px 0 0;
            color: var(--muted);
            font-size: 12px;
        }

        .nav-group { display: grid; gap: 8px; }
        .nav-label {
            margin: 18px 6px 10px;
            color: var(--muted);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .14em;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 14px;
            color: var(--muted);
            transition: background-color .18s ease, color .18s ease, transform .18s ease;
        }

        .nav-link:hover { background: rgba(148, 163, 184, .08); color: var(--text); }
        .nav-link.active {
            background: rgba(99, 102, 241, .16);
            color: var(--text);
            box-shadow: inset 0 0 0 1px rgba(99, 102, 241, .18);
        }

        .nav-dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: currentColor;
            opacity: .8;
            flex: 0 0 auto;
        }

        .sidebar-footer {
            margin-top: 20px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }

        .main {
            min-width: 0;
            padding: 20px;
        }

        .main-inner {
            width: 100%;
            min-width: 0;
        }

        .mobile-topbar {
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 0 18px;
            margin-bottom: 18px;
        }

        .mobile-brand {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .mobile-brand strong { font-size: 15px; letter-spacing: -.02em; }
        .mobile-brand span { color: var(--muted); font-size: 12px; }

        .menu-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            height: 42px;
            padding: 0 14px;
            border: 1px solid var(--border);
            border-radius: 12px;
            background: rgba(15, 23, 42, .8);
            color: var(--text);
            cursor: pointer;
            box-shadow: var(--shadow);
        }

        .menu-toggle span { font-size: 15px; line-height: 1; }

        .dashboard-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 23, .55);
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
            z-index: 40;
        }

        .page-title {
            margin: 0;
            font-size: clamp(28px, 3vw, 40px);
            line-height: 1.05;
            letter-spacing: -.045em;
        }

        .subtitle, .muted { color: var(--muted); }
        .subtitle { margin-top: 10px; max-width: 80ch; line-height: 1.65; }

        .toolbar,
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .grid { display: grid; gap: 16px; }
        .grid-2 { grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); }
        .grid-3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
        .grid-4 { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
        .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
        .split { display: grid; grid-template-columns: 1.5fr .95fr; gap: 16px; }
        .stack { display: grid; gap: 16px; }
        .section { margin-top: 24px; }

        .card {
            background: linear-gradient(180deg, rgba(17, 24, 39, .98), rgba(15, 23, 42, .92));
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            padding: 20px;
        }

        .card h3,
        .section h2,
        .section-title {
            margin: 0 0 14px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .14em;
            color: var(--muted);
        }

        .card .value {
            font-size: 30px;
            font-weight: 800;
            line-height: 1;
            letter-spacing: -.04em;
        }

        .value.green { color: var(--success); }
        .value.red { color: var(--danger); }
        .value.blue { color: var(--info); }
        .value.yellow { color: var(--warning); }

        .card-note { margin-top: 8px; color: var(--muted); font-size: 13px; line-height: 1.5; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            height: 40px;
            padding: 0 14px;
            border: 1px solid transparent;
            border-radius: 12px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: transform .18s ease, background-color .18s ease, border-color .18s ease, color .18s ease, opacity .18s ease;
            text-decoration: none;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-1px); }
        .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-strong)); color: #fff; box-shadow: 0 10px 24px rgba(99, 102, 241, .28); }
        .btn-primary:hover { color: #fff; }
        .btn-secondary { background: rgba(148, 163, 184, .12); color: var(--text); border-color: rgba(148, 163, 184, .14); }
        .btn-danger { background: rgba(239, 68, 68, .14); color: #fecaca; border-color: rgba(239, 68, 68, .18); }
        .btn-ghost { background: transparent; color: var(--text); border-color: var(--border); }

        .pill,
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            line-height: 1;
            white-space: nowrap;
        }

        .pill { background: rgba(148, 163, 184, .12); color: var(--muted); }
        .badge-green { background: rgba(34, 197, 94, .14); color: #86efac; }
        .badge-red { background: rgba(239, 68, 68, .14); color: #fca5a5; }
        .badge-yellow { background: rgba(245, 158, 11, .14); color: #fcd34d; }
        .badge-blue { background: rgba(56, 189, 248, .14); color: #7dd3fc; }

        .empty,
        .alert {
            border: 1px solid var(--border);
            border-radius: var(--radius);
            background: rgba(15, 23, 42, .78);
            box-shadow: var(--shadow);
        }

        .empty {
            text-align: center;
            padding: 44px 24px;
            color: var(--muted);
        }

        .empty h3 { margin: 0 0 8px; color: var(--text); font-size: 18px; letter-spacing: -.02em; }
        .empty p { margin: 0; line-height: 1.6; }

        .alert {
            margin-bottom: 18px;
            padding: 14px 16px;
            background: rgba(127, 29, 29, .36);
            color: #fecaca;
        }

        .alert strong { display: block; margin-bottom: 8px; }
        .alert ul { margin: 0; padding-left: 18px; }

        .table-card { padding: 0; overflow: hidden; }
        .table-scroll {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 14px;
        }

        .wide-table { min-width: max-content; }

        thead th {
            position: sticky;
            top: 0;
            z-index: 1;
            text-align: left;
            padding: 14px 16px;
            color: var(--muted);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .14em;
            background: rgba(15, 23, 42, .98);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(148, 163, 184, .12);
            vertical-align: top;
        }

        tbody tr:hover td { background: rgba(148, 163, 184, .04); }

        .mono {
            font-family: var(--mono);
            font-size: 12px;
            letter-spacing: .01em;
        }

        .field label,
        .form-label,
        dt label {
            display: block;
            margin-bottom: 8px;
            color: var(--muted);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .14em;
        }

        input,
        select,
        textarea {
            width: 100%;
            min-height: 42px;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 12px;
            background: rgba(15, 23, 42, .88);
            color: var(--text);
            outline: none;
            font: inherit;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: rgba(99, 102, 241, .55);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, .16);
        }

        .filters,
        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
        }

        .field { min-width: 0; }
        .field-actions { display: flex; align-items: end; gap: 8px; flex-wrap: wrap; }

        .def-list {
            display: grid;
            grid-template-columns: minmax(120px, 180px) minmax(0, 1fr);
            gap: 10px 16px;
            margin: 0;
            font-size: 14px;
        }

        .def-list dt { color: var(--muted); }
        .def-list dd { margin: 0; font-weight: 500; }

        .chart-list { display: grid; gap: 12px; }
        .chart-row {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(0, 3.8fr) auto;
            gap: 12px;
            align-items: center;
        }

        .chart-label,
        .chart-value {
            font-size: 13px;
            line-height: 1.35;
        }

        .chart-label {
            color: var(--text);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .chart-meta { color: var(--muted); font-variant-numeric: tabular-nums; white-space: nowrap; }
        .chart-track {
            position: relative;
            height: 11px;
            border-radius: 999px;
            overflow: hidden;
            background: rgba(148, 163, 184, .12);
        }

        .chart-fill {
            height: 100%;
            border-radius: inherit;
            background: var(--bar-color, linear-gradient(90deg, var(--primary), #8b5cf6));
            box-shadow: 0 0 20px rgba(99, 102, 241, .18);
        }

        .chart-note { margin-top: 12px; color: var(--muted); font-size: 12px; }

        .statline {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 11px 0;
            border-bottom: 1px solid rgba(148, 163, 184, .12);
        }

        .statline:last-child { border-bottom: 0; padding-bottom: 0; }
        .statline:first-child { padding-top: 0; }

        .split-grid { display: grid; gap: 16px; }

        .stack-list { margin: 0; padding-left: 18px; color: var(--text); }
        .stack-list li + li { margin-top: 8px; }

        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }

        @media (max-width: 1024px) {
            .dashboard-shell { grid-template-columns: 1fr; }
            .split { grid-template-columns: 1fr; }
            .sidebar {
                position: fixed;
                inset: 0 auto 0 0;
                width: min(88vw, 320px);
                transform: translateX(-102%);
                transition: transform .24s ease;
                box-shadow: 24px 0 60px rgba(2, 6, 23, .35);
            }
            body.sidebar-open .sidebar { transform: translateX(0); }
            body.sidebar-open .dashboard-backdrop { opacity: 1; pointer-events: auto; }
            .dashboard-backdrop { display: block; }
            .mobile-topbar { display: flex; }
            .main { padding: 16px; }
        }

        @media (max-width: 700px) {
            .grid-2 { grid-template-columns: 1fr; }
            .def-list { grid-template-columns: 1fr; }
            .chart-row { grid-template-columns: 1fr; gap: 8px; }
            .chart-meta { justify-self: start; }
            .toolbar, .page-header { align-items: stretch; }
            .page-title { font-size: clamp(24px, 8vw, 32px); }
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <div class="dashboard-backdrop" data-sidebar-backdrop></div>
    <div class="dashboard-shell">
        <aside class="sidebar" aria-label="Primary navigation">
            <div class="brand">
                <div class="brand-mark" aria-hidden="true"></div>
                <div>
                    <h1>AIGateway</h1>
                    <p>Dashboard v1.0</p>
                </div>
            </div>

            <nav class="nav-group">
                <div class="nav-label">Explore</div>
                <a href="{{ dash.turl('/dashboard', dashboard_token|default('')) }}" class="nav-link {% if app.request.pathInfo == '/dashboard' or (dashboard_token|default('') and app.request.pathInfo ends with '/dashboard') %}active{% endif %}" {% if app.request.pathInfo == '/dashboard' %}aria-current="page"{% endif %}><span class="nav-dot"></span>Overview</a>
                <a href="{{ dash.turl('/dashboard/analytics', dashboard_token|default('')) }}" class="nav-link {% if '/analytics' in app.request.pathInfo %}active{% endif %}" {% if '/analytics' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>Analytics</a>
                <a href="{{ dash.turl('/dashboard/requests', dashboard_token|default('')) }}" class="nav-link {% if '/requests' in app.request.pathInfo %}active{% endif %}" {% if '/requests' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>Requests</a>

                <div class="nav-label">Manage</div>
                <a href="{{ dash.turl('/dashboard/providers', dashboard_token|default('')) }}" class="nav-link {% if '/providers' in app.request.pathInfo %}active{% endif %}" {% if '/providers' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>Providers</a>
                <a href="{{ dash.turl('/dashboard/models', dashboard_token|default('')) }}" class="nav-link {% if '/models' in app.request.pathInfo %}active{% endif %}" {% if '/models' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>Models</a>
                <a href="{{ dash.turl('/dashboard/chains', dashboard_token|default('')) }}" class="nav-link {% if '/chains' in app.request.pathInfo %}active{% endif %}" {% if '/chains' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>Model Chains</a>
                <a href="{{ dash.turl('/dashboard/teams', dashboard_token|default('')) }}" class="nav-link {% if '/teams' in app.request.pathInfo %}active{% endif %}" {% if '/teams' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>Teams</a>
                <a href="{{ dash.turl('/dashboard/keys', dashboard_token|default('')) }}" class="nav-link {% if '/keys' in app.request.pathInfo %}active{% endif %}" {% if '/keys' in app.request.pathInfo %}aria-current="page"{% endif %}><span class="nav-dot"></span>API Keys</a>
            </nav>

            <div class="sidebar-footer">
                <a href="{{ dash.turl('/v1/health', dashboard_token|default('')) }}" class="nav-link"><span class="nav-dot"></span>Health API</a>
            </div>
        </aside>

        <main class="main">
            <div class="main-inner">
                <div class="mobile-topbar">
                    <button class="menu-toggle" type="button" data-sidebar-toggle aria-label="Open navigation"><span>☰</span> Menu</button>
                    <div class="mobile-brand">
                        <strong>AIGateway Dashboard</strong>
                        <span>Operations at a glance</span>
                    </div>
                </div>

                {% if errors is defined and errors|length > 0 %}
                    <div class="alert">
                        <strong>Erreur :</strong>
                        <ul>
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% block content %}{% endblock %}
            </div>
        </main>
    </div>

    <script>
        (function () {
            const body = document.body;
            const toggle = document.querySelector('[data-sidebar-toggle]');
            const backdrop = document.querySelector('[data-sidebar-backdrop]');
            const close = () => body.classList.remove('sidebar-open');
            const open = () => body.classList.add('sidebar-open');

            if (toggle) {
                toggle.addEventListener('click', () => {
                    body.classList.contains('sidebar-open') ? close() : open();
                });
            }

            if (backdrop) backdrop.addEventListener('click', close);

            document.querySelectorAll('.sidebar a').forEach(link => {
                link.addEventListener('click', () => {
                    if (window.matchMedia('(max-width: 1024px)').matches) close();
                });
            });

            window.addEventListener('resize', () => {
                if (!window.matchMedia('(max-width: 1024px)').matches) close();
            });
        })();
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
